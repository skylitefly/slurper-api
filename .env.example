# Django
SKYLITE_DJANGO_SECRET_KEY=change-me
SKYLITE_DJANGO_DEBUG=false
SKYLITE_DJANGO_ALLOWED_HOSTS=slurper.skylitefly.com,localhost,127.0.0.1

# Redis cache. Leave unset to use Django local-memory cache in simple local runs.
SKYLITE_REDIS_DEFAULT_LOCATION=redis://redis:6379/0
SKYLITE_REDIS_DEFAULT_PASSWORD=
SKYLITE_REDIS_DEFAULT_KEY_PREFIX=slurper

# Whazzup upstream
SKYLITE_SLURPER_WHAZZUP_URL=https://fsddata.skylitefly.com/whazzup.json
SKYLITE_SLURPER_WHAZZUP_TIMEOUT_SECONDS=5
SKYLITE_SLURPER_WHAZZUP_CACHE_SECONDS=5
